# Copy this file to ".env" and fill in your values. Never commit .env.

# Required: your bot token from the Discord Developer Portal.
DISCORD_TOKEN=

# Optional: restrict the bot to a single channel (right-click channel > Copy Channel ID,
# with Developer Mode enabled). Leave empty to react in every channel the bot can see.
CHANNEL_ID=

# Optional: whisper model (tiny/base/small/medium/large-v3). Default: large-v3
WHISPER_MODEL=large-v3

# Optional: forced language code (e.g. fr, en). Use "auto" to auto-detect. Default: fr
LANGUAGE=fr
